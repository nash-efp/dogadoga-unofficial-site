---
// Splash.astro - ターミナル風起動演出
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="splash-screen" class="fixed inset-0 z-50 bg-[#0d0d0d] flex items-center justify-center overflow-hidden">
  <!-- グレイン・ノイズ背景 -->
  <div class="grain-overlay absolute inset-0 pointer-events-none opacity-30"></div>

  <!-- スキャンライン -->
  <div class="scanline absolute inset-0 pointer-events-none"></div>

  <!-- ターミナルウィンドウ -->
  <div class="terminal-window relative w-full max-w-5xl mx-4 border border-neon-green/60 rounded-sm shadow-[0_0_40px_rgba(57,255,20,0.3)]">
    <!-- タイトルバー -->
    <div class="terminal-titlebar flex items-center gap-2 px-5 py-3 bg-[#1a1a1a] border-b border-neon-green/30">
      <span class="w-4 h-4 rounded-full bg-[#ff5f57] block"></span>
      <span class="w-4 h-4 rounded-full bg-[#ffbd2e] block"></span>
      <span class="w-4 h-4 rounded-full bg-[#28ca41] block"></span>
      <span class="ml-4 text-neon-green/60 text-base font-mono">D.U.A. — bash — 80×24</span>
    </div>

    <!-- ターミナル本体 -->
    <div class="terminal-body p-8 font-mono text-xl leading-relaxed overflow-y-auto" style="max-height: calc(100vh - 80px);">
      <div id="boot-lines" class="space-y-2"></div>
      <div id="cursor-line" class="flex items-center mt-2 hidden">
        <span class="text-neon-green/70 text-xl">root@dua:~#&nbsp;</span>
        <span class="w-3 h-6 bg-neon-green animate-blink inline-block"></span>
      </div>

      <!-- ウェルカムメッセージ -->
      <div id="welcome-msg" class="hidden mt-8">
        <!-- バンド写真：全幅ヒーロー -->
        <div class="relative w-full">
          <img
            src={`${base}/assets/band-photo.jpg`}
            alt="DOGADOGA"
            class="w-full object-cover grayscale contrast-125 brightness-75"
            style="max-height: 520px; object-position: center top;"
          />
          <!-- グラデーションオーバーレイ -->
          <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 40%, #0d0d0d 100%);"></div>
          <!-- テキストオーバーレイ -->
          <div class="absolute bottom-0 left-0 right-0 px-8 pb-6 text-center">
            <p class="neon-pink-text font-bold tracking-widest text-lg uppercase mb-2">DOGADOGA Underground Archive</p>
            <p class="neon-green-text font-bold leading-none" style="font-size: clamp(5rem, 15vw, 11rem); letter-spacing: -0.02em;">
              DOGADOGA
            </p>
          </div>
        </div>

        <!-- 下部テキスト＋ボタン -->
        <div class="px-8 pt-6 pb-2 text-center">
          <p class="neon-green-text font-bold" style="font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.3;">
            秘密基地へようこそ！
          </p>
          <p class="text-neon-green/50 text-xl mt-3">
            ── ファンによる非公式アーカイブサイトです ──
          </p>
          <div class="mt-8 mb-4 flex justify-center">
            <button
              id="enter-btn"
              class="enter-button relative px-12 py-5 border-2 border-neon-green text-neon-green font-mono text-2xl uppercase tracking-widest transition-all duration-200 hover:bg-neon-green hover:text-[#0d0d0d] hover:shadow-[0_0_30px_rgba(57,255,20,0.9)] focus:outline-none"
            >
              [ ENTER THE BASE ]
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .grain-overlay {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  .scanline::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to bottom, transparent, rgba(57,255,20,0.08), transparent);
    animation: scanline 4s linear infinite;
  }

  @keyframes scanline {
    0%   { transform: translateY(-100vh); }
    100% { transform: translateY(100vh); }
  }

  .neon-green-text {
    color: #39ff14;
    text-shadow: 0 0 6px #39ff14, 0 0 14px #39ff14, 0 0 28px #39ff14;
  }

  .neon-pink-text {
    color: #ff00ff;
    text-shadow: 0 0 6px #ff00ff, 0 0 14px #ff00ff, 0 0 28px #ff00ff;
  }

  .enter-button::before {
    content: '';
    position: absolute;
    inset: -2px;
    background: linear-gradient(45deg, #39ff14, #ff00ff, #39ff14);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .enter-button:hover::before { opacity: 0.4; }

  .boot-line-ok::after  { content: ' [  OK  ]'; color: #39ff14; }
  .boot-line-warn::after { content: ' [ WARN ]'; color: #ffbd2e; }
</style>

<script>
  const bootSequence = [
    { text: 'Initializing D.U.A. system v0.1.0...', type: 'ok' },
    { text: 'Loading underground archive modules...', type: 'ok' },
    { text: 'Mounting /data/gigs ................................', type: 'ok' },
    { text: 'Mounting /data/discography .......................', type: 'ok' },
    { text: 'Loading psychedelic renderer......................', type: 'ok' },
    { text: 'Calibrating neon output...........................', type: 'ok' },
    { text: 'Checking jazz-fusion compatibility................', type: 'warn' },
    { text: 'WARNING: Controlled chaos detected. Continuing..', type: 'warn' },
    { text: 'Engaging punk subsystems.........................', type: 'ok' },
    { text: 'System ready. Welcome to the secret base.', type: 'ok' },
  ];

  const bootLinesEl = document.getElementById('boot-lines')!;
  const cursorLineEl = document.getElementById('cursor-line')!;
  const welcomeMsgEl = document.getElementById('welcome-msg')!;
  const enterBtn     = document.getElementById('enter-btn')!;
  const splashScreen = document.getElementById('splash-screen')!;

  function addLine(text: string, type: string) {
    const line = document.createElement('div');
    line.className = type === 'warn'
      ? 'text-yellow-400/80 boot-line-warn'
      : 'text-neon-green/80 boot-line-ok';
    line.textContent = text;
    bootLinesEl.appendChild(line);
  }

  async function wait(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  async function runBootSequence() {
    await wait(300);
    for (const item of bootSequence) {
      addLine(item.text, item.type);
      await wait(380);
    }
    cursorLineEl.classList.remove('hidden');
    await wait(700);
    cursorLineEl.classList.add('hidden');
    welcomeMsgEl.classList.remove('hidden');
  }

  enterBtn.addEventListener('click', () => {
    splashScreen.style.transition = 'opacity 0.5s ease-out';
    splashScreen.style.opacity = '0';
    setTimeout(() => {
      splashScreen.style.display = 'none';
      document.body.style.overflow = '';
    }, 500);
  });

  document.body.style.overflow = 'hidden';
  runBootSequence();
</script>
