---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const gigs = await getCollection('gigs');
  return gigs.map((g) => ({
    params: { slug: g.slug },
    props: { gig: g },
  }));
}

const { gig } = Astro.props;
const { data } = gig;
const { Content } = await gig.render();

const siteBase = 'https://nash-efp.github.io/dogadoga-unofficial-site';
const pageUrl = `${siteBase}/gigs/${gig.slug}/`;
const pageTitle = `${data.title} — ${data.venue} (${data.date}) | D.U.A. DOGADOGA`;
const pageDesc = data.notes
  ? data.notes.slice(0, 120)
  : `${data.date} ${data.venue}で行われたDOGADOGAのライブ情報${data.setlist ? `。セットリスト${data.setlist.length}曲を掲載。` : '。'}`;

const eventJsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicEvent",
  "name": data.title,
  "startDate": data.date,
  "location": {
    "@type": "MusicVenue",
    "name": data.venue,
    "addressCountry": "JP"
  },
  "performer": {
    "@type": "MusicGroup",
    "name": "DOGADOGA"
  },
  "url": pageUrl,
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={pageUrl} />

    <!-- OGP -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content="https://nash-efp.github.io/dogadoga-unofficial-site/assets/band-photo.jpg" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="D.U.A. — DOGADOGA Underground Archive" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content="https://nash-efp.github.io/dogadoga-unofficial-site/assets/band-photo.jpg" />

    <!-- JSON-LD: MusicEvent -->
    <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <style>
      body { background-color: #0d0d0d; color: #e0e0e0; }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
        background-size: 128px 128px;
        opacity: 0.06;
        pointer-events: none;
        z-index: 0;
      }
    </style>
  </head>
  <body class="bg-[#0d0d0d] text-gray-100 min-h-screen font-mono relative">
    <div class="relative z-10 max-w-3xl mx-auto px-8 py-16">

      <!-- 戻るリンク -->
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/#gigs`} class="text-neon-green/50 hover:text-neon-green text-base tracking-widest uppercase transition-colors duration-150 mb-12 inline-block"
        style="color:#39ff14; opacity:0.5;"
        onmouseover="this.style.opacity='1'"
        onmouseout="this.style.opacity='0.5'"
      >
        ← BACK TO GIGS
      </a>

      <!-- ヘッダー情報 -->
      <header class="mt-8 mb-12 border-l-4 border-neon-green/60 pl-8" style="border-color:#39ff14;">
        <p class="text-xl font-mono mb-2" style="color:#39ff14; opacity:0.6;">{data.date}</p>
        <h1 class="text-4xl font-bold text-white leading-tight mb-1">{data.title}</h1>
        {data.subtitle && (
          <p class="text-2xl text-gray-400 mb-3">{data.subtitle}</p>
        )}
        <p class="text-2xl text-gray-500">{data.venue}</p>
      </header>

      <!-- ノート -->
      {data.notes && (
        <section class="mb-10">
          <p class="text-gray-400 text-lg leading-relaxed">{data.notes}</p>
        </section>
      )}

      <!-- セットリスト -->
      {data.setlist && data.setlist.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold tracking-widest uppercase mb-6" style="color:#39ff14; text-shadow:0 0 8px #39ff14;">
            SETLIST <span class="text-lg opacity-50">({data.setlist.length}曲)</span>
          </h2>
          <ol class="space-y-2">
            {data.setlist.map((title: string, i: number) => (
              <li class="flex items-baseline gap-4 border-b border-neon-green/10 pb-2">
                <span class="text-gray-600 text-base w-7 shrink-0 text-right">{i + 1}.</span>
                <span class="text-xl text-gray-200">{title}</span>
              </li>
            ))}
          </ol>
        </section>
      )}

      <!-- 本文 (Markdown content) -->
      <div class="prose prose-invert prose-lg max-w-none text-gray-400 leading-relaxed mb-10">
        <Content />
      </div>

      <!-- 参照元 -->
      {data.source && (
        <p class="text-sm text-gray-600 mt-8">
          参照元：
          <a href={data.source} target="_blank" rel="noopener noreferrer"
            class="text-neon-green/40 hover:text-neon-green/70 underline underline-offset-2 transition-colors break-all">
            {data.source}
          </a>
        </p>
      )}

    </div>
  </body>
</html>
